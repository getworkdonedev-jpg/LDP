{
  "name": "@ldp-protocol/sdk",
  "version": "2.1.4",
  "description": "LDP — Local Data Protocol. Privacy-first AI access to personal local data.",
  "keywords": [
    "ldp",
    "local-data-protocol",
    "privacy",
    "ai",
    "personal-data",
    "mcp",
    "sqlite",
    "local-first",
    "encryption"
  ],
  "homepage": "https://github.com/getworkdonedev-jpg/LDP#readme",
  "bugs": {
    "url": "https://github.com/getworkdonedev-jpg/LDP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getworkdonedev-jpg/LDP.git"
  },
  "license": "GPL-3.0",
  "author": "Karthik Perumalla <karthikhub7@gmail.com>",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./connectors": {
      "import": "./dist/esm/connectors/index.js",
      "require": "./dist/cjs/connectors/index.js",
      "types": "./dist/types/connectors/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/esm/adapters/index.js",
      "require": "./dist/cjs/adapters/index.js",
      "types": "./dist/types/adapters/index.d.ts"
    }
  },
  "bin": {
    "ldp": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.sdk.json",
    "build:watch": "tsc -p tsconfig.sdk.json --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@journeyapps/sqlcipher": "^5.3.1",
    "@signalapp/sqlcipher": "^2.4.4",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.19.37",
    "@types/node-fetch": "^2.6.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
